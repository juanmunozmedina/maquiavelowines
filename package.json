{
	"name": "maquiavelowines.netlify.app",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": "24.3.0"
	},
	"scripts": {
		"dev:ci": "doppler run pnpm openapi-ts && doppler run astro dev",
		"dev": "astro dev",
		"start": "astro dev",
		"build:ci": "pnpm openapi-ts && pnpm astro build",
		"build": "pnpm astro build",
		"astro": "astro",
		"lint": "astro sync && run-s --continue-on-error lint:*",
		"lint:biome": "biome lint src",
		"lint:astro": "astro check",
		"lint:types": "tsc -b",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"format": "run-s --continue-on-error format:*",
		"format:biome": "biome check . --apply",
		"format:prettier": "prettier . --cache --write --list-different",
		"netlify": "netlify"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.4.11",
		"@hey-api/openapi-ts": "0.96.0",
		"@types/node": "^25.6.0",
		"netlify-cli": "^24.11.2",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.2",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-jsdoc": "^1.8.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"typescript": "^6.0.2",
		"vite-plugin-tsconfig-paths": "^1.4.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@astrojs/netlify": "^7.0.6",
		"@astrojs/partytown": "^2.1.7",
		"@astrojs/sitemap": "^3.7.2",
		"@astrojs/solid-js": "^6.0.1",
		"@fontsource-variable/inter": "5.2.8",
		"@hey-api/client-fetch": "0.13.1",
		"@iconify-json/mdi": "^1.2.3",
		"@kobalte/core": "0.13.11",
		"@kobalte/tailwindcss": "0.9.0",
		"@netlify/functions": "^5.2.0",
		"@playwright/test": "^1.59.1",
		"@sentry/astro": "^10.48.0",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/solid-query": "^5.99.0",
		"@tanstack/solid-query-devtools": "^5.99.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"astro": "^6.1.6",
		"astro-breadcrumbs": "^3.4.0",
		"astro-icon": "^1.1.5",
		"flowbite": "^4.0.1",
		"photoswipe": "^5.4.4",
		"solid-icons": "^1.2.0",
		"solid-js": "^1.9.12",
		"stripe": "22.0.1",
		"swiper": "^12.1.3",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "^4.2.2",
		"tailwindcss-animate": "^1.0.7",
		"type-fest": "^5.5.0",
		"vanilla-cookieconsent": "^3.1.0",
		"zod": "4.3.6"
	},
	"pnpm": {
		"ignoredBuiltDependencies": [
			"esbuild"
		],
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	}
}
